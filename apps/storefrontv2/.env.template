# Base URL of the Medusa backend API server (exposed to the browser)
VITE_MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key for the Medusa backend. Required for the storefront to function.
# Create one in Medusa Admin -> Settings -> Publishable API keys.
VITE_MEDUSA_PUBLISHABLE_KEY=

# Default region/country code used when none can be resolved from the request.
VITE_DEFAULT_REGION=dk

# Public base URL of this storefront (used for absolute URLs / metadata).
VITE_BASE_URL=http://localhost:8000

# Culqi public key (pk_test_... / pk_live_...). Used by Culqi Checkout to
# tokenize the card in the browser. Get it from CulqiPanel > Desarrollo > API Keys.
VITE_CULQI_PUBLIC_KEY=
