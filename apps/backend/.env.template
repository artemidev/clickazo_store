STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=
DB_NAME=medusa-backend
MEDUSA_FF_CACHING=true
# Instance role. Local dev uses "shared" (single process). In production set
# "server" on the API/admin instance and "worker" on the background-tasks instance.
MEDUSA_WORKER_MODE=shared
# Disable the admin dashboard on the worker instance (set "true" there).
DISABLE_MEDUSA_ADMIN=false

# Public URLs used to build links inside transactional emails.
MEDUSA_BACKEND_URL=http://localhost:9000
STOREFRONT_URL=http://localhost:8000

# Meilisearch. In docker dev the host is http://meilisearch:7700 and the API key
# is the master key (see docker-compose.yml). In production point these at the
# deployed Meilisearch instance and set them on BOTH the server and worker.
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# OpenAI API key used for AI-powered semantic search vector embeddings and the
# AI Product Creation feature (content generation, translation, price extraction).
# Required when vectorSearch.enabled is true in medusa-config.ts.
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Tavily search API key used by AI Product Creation to research real product
# data (specs, prices) on the web. Get a key from https://app.tavily.com.
TAVILY_API_KEY=
# Optional: override the OpenAI chat model used by AI Product Creation.
AI_PRODUCT_MODEL=gpt-4o-mini

# SMTP Config
NOTIFICATION_PROVIDER_FROM=frank.cary@clickazo.com
SMTP_HOST=mail.clickazo.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=frank.cary@clickazo.com
SMTP_PASS=

# Culqi payment gateway (https://culqi.com). Get keys from CulqiPanel > Desarrollo
# > API Keys. Required on BOTH the server and worker instances in production.
CULQI_SECRET_KEY=
CULQI_PUBLIC_KEY=
